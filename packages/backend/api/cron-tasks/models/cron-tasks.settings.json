{
  "kind": "collectionType",
  "collectionName": "cron_tasks",
  "info": {
    "name": "Cron Tasks",
    "description": ""
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "transaction_key": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "inprogress",
        "completed",
        "failed"
      ],
      "default": "inprogress",
      "required": true
    },
    "message": {
      "type": "text"
    }
  }
}
