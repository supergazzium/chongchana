  "components": {
    "schemas": {
      "Event-transaction": {
        "required": [
          "id",
          "event_id",
          "price",
          "points",
          "status",
          "req_trans_id",
          "round_id"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "user_id": {
            "required": [
              "id",
              "username",
              "email"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "username": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "provider": {
                "type": "string"
              },
              "password": {
                "type": "string"
              },
              "resetPasswordToken": {
                "type": "string"
              },
              "confirmationToken": {
                "type": "string"
              },
              "confirmed": {
                "type": "boolean"
              },
              "blocked": {
                "type": "boolean"
              },
              "role": {
                "type": "string"
              },
              "first_name": {
                "type": "string"
              },
              "last_name": {
                "type": "string"
              },
              "nickname": {
                "type": "string"
              },
              "gender": {
                "type": "string",
                "enum": [
                  "male",
                  "female",
                  "other"
                ]
              },
              "profile_image": {
                "type": "string"
              },
              "citizen_id": {
                "type": "integer"
              },
              "birthdate": {
                "type": "string"
              },
              "bookings": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "branch": {
                "type": "string"
              },
              "phone": {
                "type": "string"
              },
              "special": {
                "type": "boolean"
              },
              "points": {
                "type": "integer"
              },
              "vaccinated": {
                "type": "boolean"
              },
              "atk_expired_at": {
                "type": "string"
              },
              "atk_logs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "created_by": {
                "type": "string"
              },
              "updated_by": {
                "type": "string"
              }
            }
          },
          "event_id": {
            "type": "string"
          },
          "payment_charge_id": {
            "type": "string"
          },
          "payment_transaction_id": {
            "type": "string"
          },
          "payment_created": {
            "type": "string",
            "format": "date-time"
          },
          "payment_card_id": {
            "type": "string"
          },
          "price": {
            "type": "number",
            "default": 0
          },
          "net_amount": {
            "type": "number",
            "default": 0
          },
          "fee": {
            "type": "number",
            "default": 0
          },
          "fee_vat": {
            "type": "number",
            "default": 0
          },
          "points": {
            "type": "integer",
            "default": 0
          },
          "status": {
            "type": "string",
            "default": "pending",
            "enum": [
              "pending",
              "expired",
              "failed",
              "reversed",
              "successful",
              "refunded",
              "partial_refunded"
            ]
          },
          "event_table_reserveds": {
            "type": "array",
            "items": {
              "required": [
                "id",
                "price",
                "req_trans_id"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "zone_id": {
                  "type": "integer"
                },
                "round_id": {
                  "type": "integer"
                },
                "table_number": {
                  "type": "integer"
                },
                "price": {
                  "type": "number"
                },
                "users_permissions_user": {
                  "type": "string"
                },
                "event": {
