{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "name": "Article",
    "description": ""
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string"
    },
    "cover_image": {
      "model": "file",
      "via": "related",
      "allowedTypes": [
        "images",
        "files",
        "videos"
      ],
      "plugin": "upload",
      "required": false,
      "pluginOptions": {}
    },
    "content": {
      "type": "richtext"
    },
    "special": {
      "type": "boolean"
    },
    "excerpt": {
      "type": "text"
    },
    "slug": {
      "type": "string"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "website-settings.seo"
    }
  }
}
