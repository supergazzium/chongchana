# ========================================
# CHONGJAROEN BACKEND API - ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env and fill in the actual values
# NEVER commit .env file to git!

# ========================================
# SERVER CONFIGURATION
# ========================================
HOST=0.0.0.0
NODE_PORT=7001
NODE_ENV=development

# Website frontend URL (for CORS and redirects)
WEBSITE_ENDPOINT_URL=http://localhost:8080

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Local Development
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=chongjaroen_dev
DATABASE_USERNAME=root
DATABASE_PASSWORD=
DATABASE_SSL=false

# Production (Digital Ocean Managed Database)
# DATABASE_HOST=your-db-cluster.db.ondigitalocean.com
# DATABASE_PORT=25060
# DATABASE_NAME=chongjaroen_prod
# DATABASE_USERNAME=doadmin
# DATABASE_PASSWORD=your_secure_password_here
# DATABASE_SSL=true

# ========================================
# FILE STORAGE - DIGITAL OCEAN SPACES
# ========================================
# Get these from: https://cloud.digitalocean.com/account/api/tokens
DO_SPACE_ACCESS_KEY=your_access_key_here
DO_SPACE_SECRET_KEY=your_secret_key_here
DO_SPACE_ENDPOINT=sgp1.digitaloceanspaces.com
DO_SPACE_BUCKET=chongjaroen-assets
DO_SPACE_DIRECTORY=development
DO_SPACE_CDN=https://chongjaroen-assets.sgp1.cdn.digitaloceanspaces.com

# Production
# DO_SPACE_DIRECTORY=production

# ========================================
# SECURITY - JWT SECRETS
# ========================================
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER use these example values in production!
ADMIN_JWT_SECRET=replace_with_128_character_random_hex_string_for_admin
JWT_SECRET=replace_with_128_character_random_hex_string_for_users
BASIC_AUTHORIZATION=

# ========================================
# CORS CONFIGURATION
# ========================================
# Local Development
CORS_ORIGIN=http://localhost:3000,http://localhost:4040,http://localhost:7001,http://localhost:8080,http://192.168.1.113:8080

# Production
# CORS_ORIGIN=https://chongjaroen.com,https://admin.chongjaroen.com,https://staff.chongjaroen.com

# ========================================
# PUSH NOTIFICATIONS - ONESIGNAL
# ========================================
# Get from: https://onesignal.com/
# Create app → Settings → Keys & IDs
ONESIGNAL_APP_ID=your_onesignal_app_id_here
ONESIGNAL_API_KEY=your_onesignal_rest_api_key_here

# ========================================
# SMS PROVIDER - THAIBULK SMS
# ========================================
# Get from: https://www.thaibulksms.com/
# OTP API (for login/registration OTP)
THAIBULK_OTP_ENPOINT=https://api.thaibulksms.com/v1
THAIBULK_API_KEY=your_thaibulk_api_key
THAIBULK_API_SECRET=your_thaibulk_api_secret

# SMS API (for custom messages like PIN reset)
# Note: These are different credentials from OTP API
# Get from: https://www.thaibulksms.com/sms (SMS Console, not OTP Console)
THAIBULK_SMS_API_KEY=your_thaibulk_sms_api_key
THAIBULK_SMS_API_SECRET=your_thaibulk_sms_api_secret

# SMS Sender Name (must be pre-approved by ThaiBulkSMS)
# Contact ThaiBulkSMS support to register your sender name
# Max 11 characters for English, 15 for Thai
THAIBULK_SMS_SENDER_NAME=Chongjaroen

# ========================================
# PAYMENT GATEWAY - OMISE
# ========================================
# Get from: https://dashboard.omise.co/
#
# TEST MODE (for development/staging):
# OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxxxxx
# OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxxxx
#
# LIVE MODE (for production only):
# OMISE_SECRET_KEY=skey_xxxxxxxxxxxxxxxxxxxxx
# OMISE_PUBLIC_KEY=pkey_xxxxxxxxxxxxxxxxxxxxx

# Current: TEST MODE
OMISE_SECRET_KEY=skey_test_your_test_secret_key_here
OMISE_PUBLIC_KEY=pkey_test_your_test_public_key_here

# PromptPay QR expiration time (in minutes)
OMISE_PROMPT_PAY_EXPIRE=15

# ========================================
# DEPLOYMENT NOTES
# ========================================
#
# Digital Ocean App Platform:
# - Set NODE_PORT to ${APP_PORT} (DO provides this)
# - Enable DATABASE_SSL=true for managed database
# - Use LIVE Omise keys (not test keys)
# - Set NODE_ENV=production
#
# Webhook URL for Omise:
# - Local: http://localhost:7001/webhooks/omise (won't work)
# - Production: https://api.chongjaroen.com/webhooks/omise
#
# Database Backup:
# - Enable daily automated backups in DO dashboard
# - Retention: 7 days minimum
#
# Security Checklist:
# ✓ Rotate all JWT secrets from development
# ✓ Use new Omise keys (revoke any exposed keys)
# ✓ Never commit .env to git
# ✓ Use encrypted environment variables in DO
# ✓ Enable SSL for database connections
# ✓ Whitelist only production domains in CORS
